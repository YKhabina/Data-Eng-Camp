CREATE OR REPLACE FUNCTION export_yesterday_audit()
RETURNS VOID AS $$
DECLARE
    v_export_date DATE := (CURRENT_DATE - INTERVAL '1 day')::date;
    v_file_path text;
    v_query text;
BEGIN
    v_file_path := '/tmp/users_audit_export_' || to_char(v_export_date, 'YYYY-MM-DD') || '.csv';
    v_query := format(
        'COPY (
            SELECT user_id, changed_at, changed_by, field_changed, old_value, new_value
            FROM users_audit
            WHERE changed_at::date = %L
        ) TO %L WITH (FORMAT CSV, HEADER);',
        v_export_date, v_file_path
    );
    EXECUTE v_query;
END;
$$ LANGUAGE plpgsql;

