-- Создать запрос, показывающий:
-- Retention: сколько пользователей вернулись в течение следующих 7 дней. 
-- Формат результата - total_users_day_0|returned_in_7_days|retention_7d_percent|
--Retention = (Количество вернувшихся пользователей в дни (1...7) / 
--Общее количество пользователей в начальный день (день 0)) * 100%

WITH user_min_date AS (
    SELECT
        user_id,
        MIN(toDate(event_time)) AS cohort_day
    FROM user_events
    GROUP BY user_id
),
-- Явно связываем каждого пользователя с его когортой
user_cohort AS (
    SELECT
        user_id,
        cohort_day
    FROM user_min_date
)
SELECT
    u.cohort_day,
    COUNT(DISTINCT u.user_id) AS total_users_day_0,
    COUNT(DISTINCT e.user_id) AS returned_in_7_days,
    ROUND((COUNT(DISTINCT e.user_id) / COUNT(DISTINCT u.user_id)) * 100, 1) AS retention_7d_percent
FROM user_cohort u
LEFT JOIN user_events e ON e.user_id = u.user_id
    AND toDate(e.event_time) BETWEEN u.cohort_day + 1 AND u.cohort_day + 7
GROUP BY u.cohort_day
ORDER BY u.cohort_day;


-- Создать запрос с группировками по быстрой аналитике по дням, формат ниже.

SELECT
    event_date,
    event_type,
    uniqMerge(uniq_users) AS unique_users,      
    sumMerge(total_points_spent) AS total_points, 
    countMerge(total_actions) AS total_actions   
FROM user_events_agg
WHERE event_date >= today() - 5  --поставила за 5 дней 
GROUP BY event_date, event_type
ORDER BY event_date DESC, event_type;
